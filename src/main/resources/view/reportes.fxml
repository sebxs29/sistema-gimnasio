<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" maxHeight="Infinity" maxWidth="Infinity" prefHeight="600.0" prefWidth="900.0" spacing="20.0" stylesheets="@../css/estilos.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ReporteController">

   <styleClass>
      <String fx:value="vista" />
      <String fx:value="reportes-root" />
   </styleClass>

   <children>

      <HBox alignment="CENTER">
         <children>
            <Label styleClass="titulo-vista" text="Reportes generales" />
         </children>
      </HBox>

      <HBox alignment="CENTER">
         <children>
            <Label styleClass="subtitulo-vista" text="Resumen actual de la información registrada en el gimnasio" />
         </children>
      </HBox>

      <GridPane alignment="CENTER" hgap="25.0" vgap="25.0" VBox.vgrow="ALWAYS">

         <styleClass>
            <String fx:value="reportes-grid" />
         </styleClass>

         <columnConstraints>
            <ColumnConstraints halignment="CENTER" hgrow="ALWAYS" minWidth="280.0" prefWidth="320.0" />

            <ColumnConstraints halignment="CENTER" hgrow="ALWAYS" minWidth="280.0" prefWidth="320.0" />
         </columnConstraints>

         <rowConstraints>
            <RowConstraints minHeight="150.0" prefHeight="150.0" vgrow="SOMETIMES" />

            <RowConstraints minHeight="150.0" prefHeight="150.0" vgrow="SOMETIMES" />
         </rowConstraints>

         <children>

            <VBox alignment="CENTER" prefHeight="150.0" prefWidth="320.0" spacing="15.0" GridPane.columnIndex="0" GridPane.rowIndex="0">

               <styleClass>
                  <String fx:value="reporte-card" />
                  <String fx:value="reporte-clientes" />
               </styleClass>

               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>

               <children>
                  <Label styleClass="reporte-titulo" text="Clientes activos" />

                  <Label fx:id="lblTotalClientesActivos" styleClass="reporte-numero" text="0" />
               </children>
            </VBox>

            <VBox alignment="CENTER" prefHeight="150.0" prefWidth="320.0" spacing="15.0" GridPane.columnIndex="1" GridPane.rowIndex="0">

               <styleClass>
                  <String fx:value="reporte-card" />
                  <String fx:value="reporte-entrenadores" />
               </styleClass>

               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>

               <children>
                  <Label styleClass="reporte-titulo" text="Total de entrenadores" />

                  <Label fx:id="lblTotalEntrenadores" styleClass="reporte-numero" text="0" />
               </children>
            </VBox>

            <VBox alignment="CENTER" prefHeight="150.0" prefWidth="320.0" spacing="15.0" GridPane.columnIndex="0" GridPane.rowIndex="1">

               <styleClass>
                  <String fx:value="reporte-card" />
                  <String fx:value="reporte-planes" />
               </styleClass>

               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>

               <children>
                  <Label styleClass="reporte-titulo" text="Total de planes" />

                  <Label fx:id="lblTotalPlanes" styleClass="reporte-numero" text="0" />
               </children>
            </VBox>

            <VBox alignment="CENTER" prefHeight="150.0" prefWidth="320.0" spacing="15.0" GridPane.columnIndex="1" GridPane.rowIndex="1">

               <styleClass>
                  <String fx:value="reporte-card" />
                  <String fx:value="reporte-rutinas" />
               </styleClass>

               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>

               <children>
                  <Label styleClass="reporte-titulo" text="Rutinas asignadas" />

                  <Label fx:id="lblTotalRutinasAsignadas" styleClass="reporte-numero" text="0" />
               </children>
            </VBox>

         </children>
      </GridPane>

   </children>
</VBox>
