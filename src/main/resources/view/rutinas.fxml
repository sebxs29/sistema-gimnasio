<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="550.0" prefWidth="650.0" spacing="20.0" styleClass="vista" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.RutinaController">
    <children>
        <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" styleClass="header-bar">
            <children>
                <Label styleClass="titulo-vista" text="GESTIÓN DE RUTINAS" />
            </children>
        </HBox>
        <GridPane hgap="20.0" vgap="20.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="150.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="60.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            </rowConstraints>
            <children>
                <Label text="Nombre:" />
                <Label text="Descripción:" GridPane.rowIndex="1" />
                <Label text="Nivel:" GridPane.rowIndex="2" />
                <TextField fx:id="txtNombre" promptText="Rutina de fuerza" GridPane.columnIndex="1" />
                <TextArea fx:id="txtDescripcion" prefHeight="60.0" promptText="Descripción de la rutina" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                <ComboBox fx:id="cmbNivel" prefWidth="220.0" promptText="Seleccione" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            </children>
        </GridPane>
        <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="20.0">
            <children>
                <Button mnemonicParsing="false" onAction="#guardarRutina" styleClass="btn-primary" text="Guardar" />
                <Button mnemonicParsing="false" onAction="#actualizarRutina" styleClass="btn-secondary" text="Actualizar" />
                <Button mnemonicParsing="false" onAction="#eliminarRutina" styleClass="btn-danger" text="Eliminar" />
                <Button mnemonicParsing="false" onAction="#limpiarCampos" styleClass="btn-neutral" text="Limpiar" />
            </children>
            <padding>
                <Insets bottom="10.0" top="10.0" />
            </padding>
        </HBox>
        <TableView fx:id="tblRutinas" prefHeight="250.0" prefWidth="200.0">
            <columns>
                <TableColumn fx:id="colId" prefWidth="75.0" text="ID" />
                <TableColumn fx:id="colNombre" prefWidth="120.0" text="NOMBRE" />
                <TableColumn fx:id="colDescripcion" prefWidth="220.0" text="DESCRIPCIÓN" />
                <TableColumn fx:id="colNivel" prefWidth="120.0" text="NIVEL" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>