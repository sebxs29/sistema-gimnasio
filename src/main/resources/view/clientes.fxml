<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="600.0" spacing="20.0" styleClass="vista" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ClienteController">
    <children>
        <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" styleClass="header-bar">
            <children>
                <Label styleClass="titulo-vista" text="GESTIÓN DE CLIENTES" />
            </children>
        </HBox>
        <GridPane alignment="CENTER_LEFT" hgap="20.0" vgap="20.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            </rowConstraints>
            <children>
                <Label text="Cédula:" />
                <Label text="Nombre:" GridPane.rowIndex="1" />
                <Label text="Apellido:" GridPane.rowIndex="2" />
                <Label text="Telefono:" GridPane.rowIndex="3" />
                <Label text="Correo:" GridPane.rowIndex="4" />
                <Label text="Usuario:" GridPane.rowIndex="5" />
                <Label text="Contraseña:" GridPane.rowIndex="6" />
                <Label text="Estado:" GridPane.rowIndex="7" />
                <TextField fx:id="txtCedula" promptText="1234567890" GridPane.columnIndex="1" />
                <TextField fx:id="txtNombre" promptText="Sebastián" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                <TextField fx:id="txtApellido" promptText="Toapanta" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                <TextField fx:id="txtTelefono" promptText="0984969316" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                <TextField fx:id="txtCorreo" promptText="sebas29t@gmail.com" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                <TextField fx:id="txtUsuario" promptText="sebxs29" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                <PasswordField fx:id="txtContrasena" promptText="••••••••" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                <ComboBox fx:id="cbEstado" prefHeight="26.0" promptText="Seleccione" GridPane.columnIndex="1" GridPane.rowIndex="7" />
            </children>
        </GridPane>
        <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="20.0">
            <children>
                <Button mnemonicParsing="false" onAction="#guardarCliente" styleClass="btn-primary" text="Guardar" />
                <Button mnemonicParsing="false" onAction="#actualizarCliente" styleClass="btn-secondary" text="Actualizar" />
                <Button mnemonicParsing="false" onAction="#eliminarCliente" styleClass="btn-danger" text="Eliminar" />
                <Button mnemonicParsing="false" onAction="#limpiarCampos" styleClass="btn-neutral" text="Limpiar" />
            </children>
            <padding>
                <Insets bottom="10.0" top="10.0" />
            </padding>
        </HBox>
        <TableView fx:id="tblClientes" prefHeight="300.0" prefWidth="200.0">
            <columns>
                <TableColumn fx:id="colId" prefWidth="75.0" text="ID" />
                <TableColumn fx:id="colCedula" prefWidth="75.0" text="CÉDULA" />
                <TableColumn fx:id="colNombre" prefWidth="75.0" text="NOMBRE" />
                <TableColumn fx:id="colApellido" prefWidth="75.0" text="APELLIDO" />
                <TableColumn fx:id="colTelefono" prefWidth="75.0" text="TELEFONO" />
                <TableColumn fx:id="colCorreo" prefWidth="75.0" text="CORREO" />
                <TableColumn fx:id="colEstado" prefWidth="75.0" text="ESTADO" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
