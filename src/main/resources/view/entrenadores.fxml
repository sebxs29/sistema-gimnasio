<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane styleClass="vista" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.EntrenadorController">

    <children>

        <VBox spacing="15" AnchorPane.bottomAnchor="15" AnchorPane.leftAnchor="15" AnchorPane.rightAnchor="15" AnchorPane.topAnchor="15">

            <Label styleClass="titulo-vista" text="GESTIÓN DE ENTRENADORES" />

            <Separator />

            <GridPane hgap="10" vgap="10">

                <Label text="Cédula:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="txtCedula" promptText="Ingrese la cédula" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="Nombre:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <TextField fx:id="txtNombre" promptText="Ingrese el nombre" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Apellido:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <TextField fx:id="txtApellido" promptText="Ingrese el apellido" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Label text="Especialidad:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <ComboBox fx:id="cbEspecialidad" prefWidth="220" promptText="Seleccione" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                <Label text="Teléfono:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                <TextField fx:id="txtTelefono" promptText="Ingrese el teléfono" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                <Label text="Usuario:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                <TextField fx:id="txtUsuario" promptText="Ingrese el usuario" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                <Label text="Contraseña:" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                <PasswordField fx:id="txtContrasena" promptText="Ingrese la contraseña" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                <columnConstraints>
                    <ColumnConstraints />
                    <ColumnConstraints />
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                </rowConstraints>

            </GridPane>

            <HBox spacing="10">

                <Button onAction="#guardar" styleClass="btn-primary" text="Guardar" />

                <Button onAction="#actualizar" styleClass="btn-secondary" text="Actualizar" />

                <Button onAction="#eliminar" styleClass="btn-danger" text="Eliminar" />

                <Button onAction="#limpiar" styleClass="btn-neutral" text="Limpiar" />

            </HBox>

            <TableView fx:id="tablaEntrenadores" VBox.vgrow="ALWAYS">

                <columns>

                    <TableColumn fx:id="colId" prefWidth="60" text="ID" />

                    <TableColumn fx:id="colCedula" prefWidth="120" text="Cédula" />

                    <TableColumn fx:id="colNombre" prefWidth="140" text="Nombre" />

                    <TableColumn fx:id="colApellido" prefWidth="140" text="Apellido" />

                    <TableColumn fx:id="colEspecialidad" prefWidth="170" text="Especialidad" />

                    <TableColumn fx:id="colTelefono" prefWidth="120" text="Teléfono" />

                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>

            </TableView>

        </VBox>

    </children>

</AnchorPane>
